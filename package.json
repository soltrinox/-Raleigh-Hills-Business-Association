{
  "name": "rhba-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "scrape": "tsx scripts/scrape-site.ts",
    "extract": "tsx scripts/extract-content.ts",
    "extract:bundle": "tsx scripts/extract-content-bundle.ts",
    "content:update": "npm run scrape && npm run extract && npm run extract:bundle",
    "web:install": "npx pnpm@10 -C VERCEL install --frozen-lockfile",
    "web:dev": "npx pnpm@10 -C VERCEL dev",
    "web:build": "npx pnpm@10 -C VERCEL build",
    "web:start": "npx pnpm@10 -C VERCEL start",
    "web:lint": "npx pnpm@10 -C VERCEL lint",
    "vercel:link": "npx vercel link --cwd VERCEL --yes",
    "vercel:pull": "npx vercel pull VERCEL --yes --environment=development",
    "vercel:deploy": "npx vercel deploy VERCEL",
    "vercel:deploy:prod": "npx vercel deploy VERCEL --prod"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19",
    "cheerio": "^1.2.0",
    "daisyui": "^5.5.19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "fast-xml-parser": "^5.5.11",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}

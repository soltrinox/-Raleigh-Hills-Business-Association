# Public site URL for sitemap.xml and metadata (set in Vercel → Environment Variables)
NEXT_PUBLIC_SITE_URL=https://your-deployment.vercel.app

# Resend — contact & membership forms (POST /api/contact, POST /api/join).
# When unset, optional embedded server fragments (lib/server/resend-key-part-*.ts) are used locally.
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@RaleighHillsBusinessAssn.org
CONTACT_FROM_EMAIL=no-reply@raleighhillsbusinessassn.org
